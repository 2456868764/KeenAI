# Runtime
NODE_ENV=development
PORT=8090
LOG_LEVEL=info
# LOG_FORMAT=json   # production structured logs (default: pretty in dev)

# Database (optional — default <repo-root>/data/keenai.db; relative paths are repo-root relative)
# DATABASE_URL=file:./data/keenai.db

# Auth
JWT_SECRET=change-me-in-production-min-32-chars-long-please
# Widget HMAC (optional — defaults to JWT_SECRET; run `pnpm seed` to print demo userHash)
# WIDGET_HMAC_SECRET=change-me-widget-hmac-secret-32chars-min

# Inbound email webhooks (optional — header X-KeenAI-Webhook-Secret)
# WEBHOOK_EMAIL_SECRET=change-me-webhook-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
APP_URL=http://localhost:3000

# Dashboard (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8090

# Local file uploads (optional — default `<repo>/data/uploads`)
# UPLOAD_DIR=./data/uploads
# UPLOAD_MAX_BYTES=10485760

# Copilot / LLM (optional — without key, stub provider is used)
# LLM_PROVIDER=gemini           # stub | openai | anthropic | deepseek | kimi | gemini | ollama
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
# DEEPSEEK_API_KEY=sk-...
# # DEEPSEEK_MODEL=deepseek-v4-flash
# KIMI_API_KEY=sk-...
# KIMI_MODEL=moonshot-v1-8k
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# Workflow engine (optional — default sync; set INNGEST_EVENT_KEY for Inngest)
# INNGEST_EVENT_KEY=
# INNGEST_APP_ID=keenai
# INNGEST_SCAN_CRON=*/5 * * * *
# WORKFLOW_SCAN_INTERVAL_MINUTES=0   # sync-mode background scan (Docker lite sets 5)

# Email IMAP poll (stub — set host/user when imapflow worker is wired)
# EMAIL_IMAP_HOST=
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_USER=
# EMAIL_IMAP_PASS=
# EMAIL_IMAP_MAILBOX=INBOX
# EMAIL_IMAP_POLL_INTERVAL_MINUTES=0
# INNGEST_IMAP_POLL_CRON=*/5 * * * *

# Magic link email (optional — dev logs link to console)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_FROM=noreply@keenai.local
