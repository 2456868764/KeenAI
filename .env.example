# Runtime
NODE_ENV=development
PORT=8090
LOG_LEVEL=info
# LOG_FORMAT=json   # production structured logs (default: pretty in dev)

# Database (optional — default <repo-root>/data/keenai.db; relative paths are repo-root relative)
# DATABASE_URL=file:./data/keenai.db

# Auth
JWT_SECRET=change-me-in-production-min-32-chars-long-please
# Widget HMAC (optional — defaults to JWT_SECRET; run `pnpm seed` to print demo userHash)
# WIDGET_HMAC_SECRET=change-me-widget-hmac-secret-32chars-min

# Inbound email webhooks (optional — header X-KeenAI-Webhook-Secret)
# WEBHOOK_EMAIL_SECRET=change-me-webhook-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
APP_URL=http://localhost:3000

# Dashboard (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8090

# Local file uploads (optional — default `<repo>/data/uploads`)
# UPLOAD_DIR=./data/uploads
# UPLOAD_MAX_BYTES=10485760

# Copilot / LLM (optional — without key, stub provider is used)
# LLM_PROVIDER=deepseek          # stub | openai | deepseek | kimi (auto if unset)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat
# KIMI_API_KEY=sk-...
# KIMI_MODEL=moonshot-v1-8k

# Magic link email (optional — dev logs link to console)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_FROM=noreply@keenai.local
