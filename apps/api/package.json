{
  "name": "@keenai/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "start": "bun --env-file=../../.env src/index.ts",
    "seed": "bun --env-file=../../.env src/seed.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.2",
    "@keenai/auth": "workspace:*",
    "@keenai/channels-email": "workspace:*",
    "@keenai/llm": "workspace:*",
    "@keenai/shared": "workspace:*",
    "@keenai/storage": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.16",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.2"
  }
}
