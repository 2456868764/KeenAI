{
  "name": "@keenai/storage",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/sqlite/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts"
  },
  "dependencies": {
    "@keenai/shared": "workspace:*",
    "@keenai/workflow": "workspace:*",
    "@libsql/client": "^0.14.0",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2"
  }
}
