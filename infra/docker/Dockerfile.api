FROM oven/bun:1.2-alpine AS base
WORKDIR /app

RUN apk add --no-cache wget

COPY package.json pnpm-workspace.yaml turbo.json tsconfig.base.json biome.json pnpm-lock.yaml ./
COPY apps ./apps
COPY packages ./packages
COPY infra/docker/api-entrypoint.sh /entrypoint.sh

RUN chmod +x /entrypoint.sh && bun install -g pnpm && pnpm install --filter @keenai/api...

WORKDIR /app/apps/api
EXPOSE 8090
ENTRYPOINT ["/entrypoint.sh"]
